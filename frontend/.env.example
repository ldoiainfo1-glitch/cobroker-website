# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Co-BROKINGS
VITE_APP_URL=http://localhost:5173

# ─── Backend API (Phase 0 backend — not built yet) ────────────────────────────
VITE_API_URL=http://localhost:3001/api

# ─── AWS S3 (public values only — secrets stay in Supabase Edge Function) ─────
# ⚠️  NEVER put AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here!
# Those are set as Supabase secrets (server-side only):
#   supabase secrets set AWS_ACCESS_KEY_ID=xxx
#   supabase secrets set AWS_SECRET_ACCESS_KEY=xxx
#   supabase secrets set AWS_REGION=ap-south-1
#   supabase secrets set AWS_S3_BUCKET=cobrokings-media
#   supabase secrets set AWS_CLOUDFRONT_URL=https://xxx.cloudfront.net  (optional)
VITE_AWS_REGION=ap-south-1
VITE_AWS_S3_BUCKET=cobrokings-media
VITE_AWS_CLOUDFRONT_URL=
